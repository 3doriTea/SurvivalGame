root = true

# 全ファイル共通
[*]
charset = utf-8
end_of_line = crlf
trim_trailing_whitespace = true

# C++とHLSL
[*.{cpp,h,hlsli,hlsl}]
insert_final_newline = true
indent_style = tab
indent_size = 4

# テキストデータフォーマット
[*.{json,yaml}]
insert_final_newline = false
indent_style = space
indent_size = 2
end_of_line = lf

# Markdown
[*.{md}]
insert_final_newline = true
indent_style = space
indent_size = 2
end_of_line = lf
